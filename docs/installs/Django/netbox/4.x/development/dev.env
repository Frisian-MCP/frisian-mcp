NETBOX_DB_HOST=db
NETBOX_DB_NAME=netbox
NETBOX_DB_USER=netbox
NETBOX_DB_PASSWORD=decinablesprewad
NETBOX_DB_PORT=

NETBOX_REDIS_HOST=redis
NETBOX_REDIS_PORT=6379
NETBOX_REDIS_PASSWORD=

# Postgres container vars (must match DB values above)
POSTGRES_DB=netbox
POSTGRES_USER=netbox
POSTGRES_PASSWORD=decinablesprewad

# Superuser — created by docker-entrypoint.frisian-mcp.sh on first start
NETBOX_SUPERUSER_NAME=admin
NETBOX_SUPERUSER_EMAIL=admin@example.com
NETBOX_SUPERUSER_PASSWORD=admin
NETBOX_SUPERUSER_API_TOKEN=0123456789abcdef0123456789abcdef01234567

# frisian-mcp OAuth
# FRISIAN_MCP_OAUTH_ISSUER is intentionally unset — the issuer is derived
# dynamically from the request Host + X-Forwarded-Proto (works with ngrok).
FRISIAN_MCP_HMAC_KEY=dev-hmac-key-not-secure-replace-in-prod
