# prod.env — reference environment file for a production Nautobot deployment
# with frisian-mcp.  Replace every value below before deploying.
#
# Secrets MUST be generated with a cryptographically random source.  Examples:
#   NAUTOBOT_SECRET_KEY:     python -c "import secrets; print(secrets.token_urlsafe(64))"
#   NAUTOBOT_DB_PASSWORD:    python -c "import secrets; print(secrets.token_hex(16))"
#   NAUTOBOT_REDIS_PASSWORD: python -c "import secrets; print(secrets.token_hex(16))"
#   FRISIAN_MCP_HMAC_KEY:    python -c "import secrets; print(secrets.token_hex(32))"

# --- Public hostnames ------------------------------------------------------
# Whitespace-separated.  Include the public FQDN, container DNS aliases, and
# any internal addresses your reverse proxy forwards from.
NAUTOBOT_ALLOWED_HOSTS="your-nautobot.example.com .example.com localhost 127.0.0.1"

# --- Nautobot core ---------------------------------------------------------
NAUTOBOT_SECRET_KEY=replace-with-generated-secret
NAUTOBOT_DEBUG=False
NAUTOBOT_CHANGELOG_RETENTION=90
NAUTOBOT_NAPALM_TIMEOUT=5
NAUTOBOT_INSTALLATION_METRICS_ENABLED=false
NAUTOBOT_LOG_DEPRECATION_WARNINGS=false

# --- Postgres --------------------------------------------------------------
NAUTOBOT_DB_HOST=db
NAUTOBOT_DB_NAME=nautobot
NAUTOBOT_DB_USER=nautobot
NAUTOBOT_DB_PASSWORD=replace-with-generated-password
NAUTOBOT_DB_TIMEOUT=60

# Postgres container env (must match DB values above).
PGPASSWORD=replace-with-generated-password
POSTGRES_DB=nautobot
POSTGRES_USER=nautobot
POSTGRES_PASSWORD=replace-with-generated-password

# --- Redis -----------------------------------------------------------------
NAUTOBOT_REDIS_HOST=redis
NAUTOBOT_REDIS_PORT=6379
NAUTOBOT_REDIS_PASSWORD=replace-with-generated-password
REDIS_PASSWORD=replace-with-generated-password
REDISCLI_AUTH=replace-with-generated-password

# --- Initial superuser (created on first nautobot-server migrate) ---------
NAUTOBOT_CREATE_SUPERUSER=true
NAUTOBOT_SUPERUSER_NAME=admin
NAUTOBOT_SUPERUSER_EMAIL=admin@example.com
NAUTOBOT_SUPERUSER_PASSWORD=replace-with-strong-password
NAUTOBOT_SUPERUSER_API_TOKEN=replace-with-generated-token

# --- frisian-mcp -----------------------------------------------------------
# Public origin = the LB-terminated public URL.  Do NOT include a port if a
# reverse proxy terminates TLS on the standard 443.
FRISIAN_MCP_OAUTH_ISSUER=https://your-nautobot.example.com

# Trusted proxy hops between the public URL and Nautobot.  Set to the
# number of reverse proxies in front (e.g. 1 for a single nginx, 2 for
# nginx behind a cloud load balancer).
FRISIAN_MCP_TRUSTED_PROXY_COUNT=1

# Dedicated HMAC key — decouples frisian-mcp tokens / client secrets from
# Nautobot's SECRET_KEY so rotating one does not invalidate the other.
FRISIAN_MCP_HMAC_KEY=replace-with-generated-secret

# Prometheus metrics endpoint — leave disabled unless wired to a scraper.
METRICS_ENABLED=false
